# JARVIS API — copy to `.env` in this directory (same folder as pyproject.toml).
# Pydantic loads `JARVIS_*` from env; optional file `.env` here is read automatically.

# --- Core ---
JARVIS_APP_NAME=JARVIS API
JARVIS_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
JARVIS_DATA_DIR=.jarvis_data

# --- Ollama / brain ---
JARVIS_OLLAMA_BASE_URL=http://127.0.0.1:11434
JARVIS_DEFAULT_OLLAMA_MODEL=llama3
JARVIS_LLM_STUB=false
JARVIS_CREW_VERBOSE=false

# --- Phase 3 automation (optional) ---
# standard = medium-risk steps need a second challenge before Hammerspoon. elevated = skip that second step (audited).
# Restricted patterns (e.g. sudo) stay blocked. Slack auto-send and git apply remain gated separately.
JARVIS_AUTONOMY_TIER=standard
JARVIS_AUTOMATION_SANDBOX=false
JARVIS_HAMMERSPOON_URL=http://127.0.0.1:17339
JARVIS_HAMMERSPOON_TOKEN=change-me-in-production
JARVIS_INTERPRETER_ENABLED=false

# --- Phase 4 Slack OAuth (required for Slack hub) ---
# Create an app at https://api.slack.com/apps — OAuth redirect must match Slack app settings.
JARVIS_SLACK_CLIENT_ID=
JARVIS_SLACK_CLIENT_SECRET=
# Must match a Redirect URL in Slack app settings exactly (127.0.0.1 vs localhost, http vs https).
# Must be http(s) — Slack does not allow bot scopes with custom URL schemes (myapp://…). PKCE (S256) is always sent on /slack/connect.
# After install, the API can redirect the browser to JARVIS_SLACK_POST_OAUTH_REDIRECT (http, custom scheme, or Electron deep link).
JARVIS_SLACK_REDIRECT_URI=http://127.0.0.1:8000/slack/oauth/callback
JARVIS_SLACK_POST_OAUTH_REDIRECT=http://127.0.0.1:5173/slack

# Fernet key (url-safe base64, 32-byte key). Leave empty for local dev key file under data_dir/slack/.
JARVIS_SLACK_ENCRYPTION_KEY=

# HMAC secret for two-step send approval tokens (recommended in production).
JARVIS_SLACK_APPROVAL_SECRET=

# Phase 4C: allow POST /slack/send after signed approval (still never auto-sends).
# When true, OAuth includes chat:write — reinstall / reconnect the Slack app after enabling.
JARVIS_SLACK_WRITE_ENABLED=false

# --- Phase 5 screen intelligence (local-first) ---
JARVIS_SCREEN_INTEL_ENABLED=true
JARVIS_SCREEN_CAPTURE_INTERVAL_S=45
JARVIS_SCREEN_MAX_CAPTURE_WIDTH=1680
JARVIS_SCREEN_CONTEXT_HISTORY_ENCRYPT=true
# Optional Fernet key for encrypted context_history.sqlite3 (else auto key under data_dir/screen/).
JARVIS_SCREEN_CONTEXT_FERNET_KEY=

# --- Sibling repos (Open Interpreter + CrewAI beside my-jarvis) ---
# Parent folder containing my-jarvis, open-interpreter, crewAI (auto-detected if unset).
JARVIS_SIBLING_WORKSPACE_PARENT=
JARVIS_OPEN_INTERPRETER_REPO_PATH=
JARVIS_CREWAI_REPO_PATH=
# Must use --server when started from JARVIS (no TTY); plain `interpreter` exits on EOF from closed stdin.
JARVIS_OPEN_INTERPRETER_START_CMD=poetry run interpreter --server
JARVIS_OPEN_INTERPRETER_SERVER_HOST=127.0.0.1
JARVIS_OPEN_INTERPRETER_SERVER_PORT=8741
# Default holds a uv subprocess idle until stopped; set to your dev server command if needed.
JARVIS_CREWAI_START_CMD=uv run python -c "import threading; threading.Event().wait()"

# --- Phase 6 system evolution (local-first; mutations gated) ---
# Monorepo root with .git — required for patch prepare/apply and optional audit subprocesses.
JARVIS_REPO_ROOT=
# Allow ruff/mypy/pytest for POST /system/audit when run_tools=true (still needs REPO_ROOT).
JARVIS_SYSTEM_ALLOW_SUBPROCESS=false
# Enable POST /system/improve/apply and rollback (requires clean git tree + approval token).
JARVIS_SYSTEM_PATCHES_ENABLED=false
# Optional HMAC secret for patch/rollback tokens (else derived like Slack approval).
JARVIS_SYSTEM_PATCH_SECRET=
# psutil-based CPU/RAM for GET /system/performance.
JARVIS_SYSTEM_METRICS_ENABLED=false
# Rotating api.log under data_dir/logs/.
JARVIS_SYSTEM_LOG_MAX_BYTES=5000000
JARVIS_SYSTEM_LOG_BACKUP_COUNT=3

# --- Autowork (bounded self-maintenance; all opt-in) ---
# Never restarts uvicorn in-process — may write data_dir/autowork/RESTART_REQUESTED.json for you to act on.
JARVIS_AUTOWORK_ENABLED=false
JARVIS_AUTOWORK_SCHEDULE_ENABLED=false
# 600–604800 seconds.
JARVIS_AUTOWORK_INTERVAL_S=86400
# Require JARVIS_SYSTEM_ALLOW_SUBPROCESS=true for subprocess steps.
JARVIS_AUTOWORK_POETRY_INSTALL=false
JARVIS_AUTOWORK_RUFF_AUTOFIX=false
JARVIS_AUTOWORK_NPM_BUILD=false
JARVIS_AUTOWORK_RESTART_REQUEST_ON_GREEN=false
JARVIS_AUTOWORK_SUBPROCESS_TIMEOUT_S=600

# --- Phase 8 digital twin + idle learning (local SQLite under data_dir/evolution/) ---
# When false, POST /evolution/idle and scheduled idle ticks are disabled.
JARVIS_EVOLUTION_IDLE_ENABLED=true
# Opt-in: asyncio background loop runs the same bounded idle cycle every N seconds (requires idle enabled).
JARVIS_EVOLUTION_IDLE_SCHEDULE_ENABLED=false
# 300–86400; default 3600 (1h).
JARVIS_EVOLUTION_IDLE_SCHEDULE_INTERVAL_S=3600
# Local knowledge graph (SQLite kg_chunks + Ollama /api/embeddings; stub uses deterministic vectors).
JARVIS_EVOLUTION_KNOWLEDGE_ENABLED=true
# Optional override for embedding model (else uses JARVIS_DEFAULT_OLLAMA_MODEL).
JARVIS_EVOLUTION_KNOWLEDGE_EMBED_MODEL=
JARVIS_EVOLUTION_KNOWLEDGE_SEARCH_MAX_ROWS=800
